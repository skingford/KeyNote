		"@types/better-sqlite3": "^7.6.13",
		"@types/marked": "^5.0.2",
		"@types/prismjs": "^1.26.6",
		"drizzle-kit": "^0.31.9",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@tailwindcss/typography": "^0.5.19",
